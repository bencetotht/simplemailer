{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "RABBITMQ_URL",
        "RABBITMQ_API_URL",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "S3_BUCKET"
      ]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^db:generate"]
    },
    "db:generate": { "cache": false },
    "db:migrate": { "cache": false },
    "clean": { "cache": false }
  }
}
