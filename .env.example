DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mailer
RABBITMQ_USER=mailer
RABBITMQ_PASS=replace-with-a-random-password
RABBITMQ_URL=amqp://mailer:replace-with-a-random-password@localhost:5672
RABBITMQ_API_URL=http://localhost:15672
RABBITMQ_API_USER=mailer
RABBITMQ_API_PASS=replace-with-a-random-password

# Generate with: openssl rand -base64 32
SECRETS_MASTER_KEY=
DASHBOARD_API_KEY=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-random-password
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=replace-with-a-random-password
S3_BUCKET=templates
S3_USE_SSL=false

SMTP_TLS_REJECT_UNAUTHORIZED=true
PREFETCH_COUNT=1
MAX_RETRIES=8
ENQUEUE_RECONCILER_INTERVAL_MS=15000
