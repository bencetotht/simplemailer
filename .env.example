DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mailer
RABBITMQ_USER=mailer
RABBITMQ_PASS=replace-with-a-random-password
RABBITMQ_URL=amqp://mailer:replace-with-a-random-password@localhost:5672
RABBITMQ_API_URL=http://localhost:15672
RABBITMQ_API_USER=mailer
RABBITMQ_API_PASS=replace-with-a-random-password

# Generate with: openssl rand -base64 32
SECRETS_MASTER_KEY=
DASHBOARD_API_KEY=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-random-password
S3_REGION=eu-central-1
S3_BUCKET=templates

# Leave these unset on AWS to use the normal AWS credential provider chain.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_SESSION_TOKEN=

# Optional for MinIO or another S3-compatible service.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_CREATE_BUCKET=false

SMTP_TLS_REJECT_UNAUTHORIZED=true
PREFETCH_COUNT=1
MAX_RETRIES=8
ENQUEUE_RECONCILER_INTERVAL_MS=15000
