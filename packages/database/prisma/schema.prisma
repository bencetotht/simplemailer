generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Accounts
model Account {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique // App User / Email address
  password  String // App Password
  emailHost String // SMTP Host
  emailPort Int @default(587) // SMTP Port
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Log       Log[]
}

// Templates
model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  filename  String
  storageType STORAGE_TYPE @default(LOCAL)
  Log       Log[]
  Bucket    Bucket?   @relation(fields: [bucketId], references: [id])
  bucketId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Buckets
model Bucket {
  id        String   @id @default(cuid())
  name      String   @unique
  path      String
  accessKeyId String
  secretAccessKey String
  region String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  templates Template[]
}

// Logs
model Log {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  recipient   String
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id])
  values      Json      @default("{}")
  status      Status    @default(PENDING)
  retryCount  Int       @default(0)
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
}

model WorkerHeartbeat {
  id            String   @id
  startedAt     DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  version       String   @default("2.0.0")
  metadata      Json     @default("{}")

  @@map("worker_heartbeats")
}

enum STORAGE_TYPE {
  S3
  LOCAL
}

enum Status {
  PENDING
  SENT
  FAILED
  RETRYING
}
