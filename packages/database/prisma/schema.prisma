generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// Accounts
model Account {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique // App User / Email address
  password  String? // Legacy plaintext app password
  passwordEnc String? // Encrypted app password envelope
  emailHost String // SMTP Host
  emailPort Int @default(587) // SMTP Port
  bulkNextAvailableAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Log       Log[]
  BulkSendBatch BulkSendBatch[]
}

// Templates
model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  filename  String
  storageType STORAGE_TYPE @default(LOCAL)
  Log       Log[]
  BulkSendBatch BulkSendBatch[]
  Bucket    Bucket?   @relation(fields: [bucketId], references: [id])
  bucketId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Buckets
model Bucket {
  id        String   @id @default(cuid())
  name      String   @unique
  path      String
  accessKeyId String? // Legacy plaintext access key
  secretAccessKey String? // Legacy plaintext secret key
  accessKeyIdEnc String? // Encrypted access key envelope
  secretAccessKeyEnc String? // Encrypted secret key envelope
  region String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  templates Template[]
}

// Logs
model Log {
  id          String    @id @default(cuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  recipient   String
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id])
  values      Json      @default("{}")
  bulkBatchId String?
  bulkBatch   BulkSendBatch? @relation(fields: [bulkBatchId], references: [id])
  bulkItemId  String?   @unique
  bulkItem    BulkSendItem? @relation("BulkItemLog", fields: [bulkItemId], references: [id])
  scheduledFor DateTime?
  status      Status    @default(ENQUEUE_PENDING)
  enqueueKey  String?   @unique
  correlationId String?
  retryCount  Int       @default(0)
  nextAttemptAt DateTime?
  lastAttemptAt DateTime?
  failureClass String?
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, scheduledFor, createdAt])
  @@index([bulkBatchId])
}

model BulkSendBatch {
  id                 String   @id @default(cuid())
  accountId          String
  account            Account  @relation(fields: [accountId], references: [id])
  templateId         String
  template           Template @relation(fields: [templateId], references: [id])
  sharedValues       Json     @default("{}")
  requestedCount     Int
  acceptedCount      Int
  rejectedCount      Int
  enqueueKey         String?  @unique
  correlationId      String?
  requestedMinDelayMs Int?
  effectiveMinDelayMs Int
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  items              BulkSendItem[]
  logs               Log[]

  @@index([createdAt])
  @@index([accountId, createdAt])
}

model BulkSendItem {
  id              String   @id @default(cuid())
  batchId         String
  batch           BulkSendBatch @relation(fields: [batchId], references: [id])
  sequence        Int
  recipient       String
  values          Json     @default("{}")
  validationError String?
  logId           String?
  log             Log?     @relation("BulkItemLog")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([batchId, sequence])
  @@index([batchId, validationError])
}

// Worker statuses
model WorkerHeartbeat {
  id            String   @id
  startedAt     DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  version       String   @default("2.0.0")
  metadata      Json     @default("{}")

  @@map("worker_heartbeats")
}

enum STORAGE_TYPE {
  S3
  LOCAL
}

enum Status {
  ENQUEUE_PENDING
  QUEUED
  PROCESSING
  PENDING
  SENT
  FAILED
  RETRYING
  DEAD
}
